# Keep the image build context small and deterministic.
#
# .git is excluded (so the build uses -buildvcs=false and version metadata comes
# from --build-arg), along with built artifacts, web dependencies, and editor
# cruft. The committed web embed placeholder (internal/webui/dist/index.html) is
# kept; only the regenerated assets are excluded.

.git
.github
.gitignore
.dockerignore

# Build outputs
bin/
dist/
*.out
*.test
coverage*
cover.out

# Supply-chain scan cache. scripts/supply-chain/verify-embedded-postgres.sh
# extracts the ~2.5G embedded-postgres runtime here for checksum-pinning and
# Trivy scanning; it is never part of the image and would bloat the build
# context (and bust the layer cache) if sent to the daemon.
.supply-chain/

# Web UI dependencies. The built internal/webui/dist assets must stay in the
# Docker context because the Go binary embeds them into the served console.
web/node_modules/

# Editor / OS cruft
.DS_Store
.idea/
.vscode/
*.swp
