              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VaultTokenLookupSelfResponse"
                }
              }
            },
            "description": "Vault/OpenBao-compatible success response."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VaultErrorResponse"
                }
              }
            },
            "description": "Vault/OpenBao-compatible error envelope."
