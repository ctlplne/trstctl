# Build artifacts
/bin/
/dist/
/site/

# Bare `go build ./cmd/...` binaries dropped at the repo root. The Makefile
# builds into dist/; these are stray local builds and must never be committed.
/trustctl
/trustctl-agent
/trustctl-cli
/trustctl-signer

# Web UI dependencies are never committed.
/web/node_modules/

# The built web console under internal/webui/dist IS committed (EXC-WIRE-04 /
# SURFACE-001): it is the artifact the Go binary embeds via //go:embed, so a plain
# `go build ./cmd/trustctl` (no `make web` step) serves the REAL React console, not a
# dead placeholder. Regenerate it with `make web` (CI re-runs this and the
# TRUSTCTL_REQUIRE_BUILT_UI release gate so the committed bundle cannot drift to the
# placeholder). Do NOT ignore it.

# Test and coverage output
*.out
*.test
coverage.*
/coverage/

# Go workspace files (not committed; per-developer)
go.work
go.work.sum

# Editor / OS cruft
.DS_Store
*.swp
*~
.idea/
.vscode/
