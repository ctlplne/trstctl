# Build artifacts
/bin/
/dist/
/.site/
/site/

# Bare `go build ./cmd/...` binaries dropped at the repo root. The Makefile
# builds into dist/; these are stray local builds and must never be committed.
/trstctl
/trstctl-agent
/trstctl-cli
/trstctl-signer

# Web UI dependencies are never committed.
/web/node_modules/
/web/coverage/

# Keep Java SDK sources trackable even if a local exclude pattern overmatches
# the com/trstctl package path.
!clients/sdk/java/src/
!clients/sdk/java/src/**

# The built web console under internal/webui/dist IS committed (EXC-WIRE-04 /
# SURFACE-001): it is the artifact the Go binary embeds via //go:embed, so a plain
# `go build ./cmd/trstctl` (no `make web` step) serves the REAL React console, not a
# dead placeholder. Regenerate it with `make web` (CI re-runs this and the
# TRSTCTL_REQUIRE_BUILT_UI release gate so the committed bundle cannot drift to the
# placeholder). Do NOT ignore it.

# Supply-chain scan cache. scripts/supply-chain/verify-embedded-postgres.sh
# extracts the ~2.5G embedded-postgres runtime into /.supply-chain for
# checksum-pinning and Trivy scanning; it is a local cache and must never be
# committed (it is also excluded from the Docker build context in .dockerignore).
/.supply-chain/

# Test and coverage output
*.out
*.test
coverage.*
/coverage/

# Go workspace files (not committed; per-developer)
go.work
go.work.sum

# Editor / OS cruft
.DS_Store
*.swp
*~
.idea/
.vscode/
